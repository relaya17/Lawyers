{
  "name": "contractlab-pro",
  "version": "1.0.0",
  "description": "ContractLab Pro - פלטפורמה מתקדמת לניהול חוזים ולמידה משפטית",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "cwebp-bin",
      "esbuild",
      "gifsicle",
      "jpegtran-bin",
      "mozjpeg",
      "optipng-bin",
      "pngquant-bin"
    ]
  },
  "scripts": {
    "dev": "turbo run dev --filter=@lawyers/web",
    "dev:server": "turbo run dev --filter=@lawyers/server",
    "dev:mobile": "turbo run start --filter=@lawyers/mobile",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "build:netlify": "turbo run build:netlify --filter=@lawyers/web",
    "build:analyze": "turbo run build:analyze --filter=@lawyers/web",
    "preview": "pnpm -F @lawyers/web preview",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:ui": "pnpm -F @lawyers/web test:ui",
    "test:coverage": "pnpm -F @lawyers/web test:coverage",
    "test:ci": "turbo run test:ci",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep accessibility",
    "test:mobile": "playwright test --grep mobile",
    "test:pwa": "playwright test --grep pwa",
    "lint": "turbo run lint",
    "lint:fix": "eslint apps packages --ext ts,tsx --fix",
    "lint:ci": "node scripts/lint-ci.mjs",
    "lint:baseline:update": "node scripts/lint-ci.mjs --update",
    "prettier:check": "prettier --check .",
    "cspell": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean",
    "clean:all": "rimraf apps/*/dist packages/*/dist node_modules pnpm-lock.yaml",
    "deps:check": "pnpm outdated",
    "deps:audit": "pnpm audit",
    "security:audit": "pnpm audit --audit-level moderate",
    "code:quality": "turbo run lint type-check",
    "postinstall": "echo 'Workspace installed successfully'",
    "playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "npm-check-updates": "^16.14.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.9",
    "prisma": "^7.8.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  }
}