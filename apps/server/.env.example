PORT=3001
NODE_ENV=development

# CORS — פורט Vite (למשל 5852), מופרד בפסיקים
CORS_ORIGIN=http://localhost:5852,http://localhost:5173

# Supabase / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# או DATABASE_SSL=true אם נדרש במפורש
DATABASE_SSL=

# JWT גישה (לפחות 32 תווים אקראיים)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_SEC=900

# Refresh (אטום, DB) — משך בימים
REFRESH_TOKEN_DAYS=7

# OTP
OTP_TTL_MINUTES=15
OTP_PEPPER=another-long-random-secret-for-otp-hashing

# אימייל (אופציונלי — בלי מפתח OTP יודפס לקונסול בפיתוח)
RESEND_API_KEY=
AUTH_EMAIL_FROM=LexStudy <onboarding@resend.dev>

# Mongo (מודולים קיימים)
MONGODB_URI=

# AI (מודולים קיימים)
OPENAI_API_KEY=
