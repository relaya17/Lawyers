PORT=3001
NODE_ENV=development

# CORS — פורט Vite (למשל 5852), מופרד בפסיקים
CORS_ORIGIN=http://localhost:5852,http://localhost:5173

# Supabase / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# או DATABASE_SSL=true אם נדרש במפורש
DATABASE_SSL=

# JWT גישה (לפחות 32 תווים אקראיים)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_SEC=900

# Refresh (אטום, DB) — משך בימים
REFRESH_TOKEN_DAYS=7

# OTP
OTP_TTL_MINUTES=15
OTP_PEPPER=another-long-random-secret-for-otp-hashing

# אימייל (אופציונלי — בלי מפתח OTP יודפס לקונסול בפיתוח)
RESEND_API_KEY=
AUTH_EMAIL_FROM=LexStudy <onboarding@resend.dev>

# Mongo (מודולים קיימים)
MONGODB_URI=

# AI (מודולים קיימים)
OPENAI_API_KEY=

# Google OAuth (אותו Client ID כמו ב-web — לאימות ID Token בשרת)
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
# מודל embeddings ל-RAG (ברירת מחדל text-embedding-3-small, 1536 מימדים)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG — הזרקת הקשר מהמאגר הווקטורי לניתוח שופט AI (Virtual Court)
# LEGAL_RAG_IN_JUDGE=true
# LEGAL_RAG_MATCH_THRESHOLD=0.45
# LEGAL_RAG_MATCH_COUNT=4
# LEGAL_RAG_VERIFIED_ONLY=false

# ─────────────────────────────────────────────────────────
# Stripe Billing (B2C bar-exam prep)
# ─────────────────────────────────────────────────────────
# מפתחות ממצב Test בדאשבורד Stripe. אל תחשפי את ה-secret בקוד לקוח!
STRIPE_SECRET_KEY=sk_test_xxx
# נוצר ב: Stripe Dashboard → Developers → Webhooks → הוספה של endpoint
#   Endpoint: https://YOUR-DOMAIN/api/billing/webhook
#   Events: checkout.session.completed, customer.subscription.*
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs (Stripe Dashboard → Products). השאירי ריק עד שתוגדר המוצר.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# מבצע השקה (אופציונלי): בלי PROMO_ENDS_AT — אין בוסט ל-Free. ISO-8601 מומלץ עם אזור זמן.
# דוגמה ל־3 חודשים מהיום: עדכני לתאריך אמיתי בהשקה.
# PROMO_ENDS_AT=2026-07-23T23:59:59+03:00
# מכסת קריאות AI ליום למשתמשי Free בזמן המבצע (VC LLM + RAG; ברירת מחדל 25).
# PROMO_FREE_AI_PER_DAY=25

# ברירת מחדל ל-return URLs כש-Origin לא מגיע מהדפדפן (וובהוק וכד')
CLIENT_ORIGIN=http://localhost:5852

# ─────────────────────────────────────────────────────────
# מבצע השקה (3 חודשים חינם + מגבלת AI יומית)
# ─────────────────────────────────────────────────────────
# כל עוד PROMO_ENDS_AT עתידי — משתמשי Free מקבלים את יכולות Student Pro
# (למעט realCaseImport/contractRiskAnalysis) ומכסת AI יומית PROMO_FREE_AI_PER_DAY.
# דוגמה (זמן ישראל, סוף 3 חודשים אחרי השקה):
# PROMO_ENDS_AT=2026-07-23T23:59:59+03:00
PROMO_ENDS_AT=
PROMO_FREE_AI_PER_DAY=25

# ─────────────────────────────────────────────────────────
# Analytics — PostHog (server-side events)
# ─────────────────────────────────────────────────────────
# Project API key (phc_*) מ-PostHog Dashboard → Project Settings → Project API Key
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
