# ============================================================
#  apps/web — משתני סביבה לדוגמה
#  העתק לקובץ .env.local ומלא ערכים אמיתיים
#  אין להכניס קובץ זה לגיט עם ערכים אמיתיים!
# ============================================================

# --- API Server ---
# חייב לכלול את הנתיב /api — תואם ל-app.use('/api', ...) בשרת
VITE_API_URL=http://localhost:4000/api

# --- WebSocket ---
VITE_WS_URL=ws://localhost:4000
VITE_WEBSOCKET_URL=ws://localhost:4000

# --- Socket.io (Realtime Virtual Court) ---
# בד"כ אותו origin של השרת ללא /api. השאר ריק ונגזור אוטומטית מ-VITE_API_URL.
# בפרודקשן: VITE_SOCKET_URL=https://api.lexstudy.co.il
VITE_SOCKET_URL=

# --- Auth Bootstrap ---
# true  = דלג על בדיקת CSRF/session בטעינה (כשהשרת לא פועל — פיתוח בלבד)
# false = נסה לאתחל session עם השרת (production / כשהשרת פועל)
VITE_SKIP_AUTH_BOOTSTRAP=false

# --- Push Notifications (VAPID) ---
# קבל מ: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# --- גרסת אפליקציה ---
VITE_APP_VERSION=1.0.0

# --- אנליטיקה / מעקב (אופציונלי) ---
# VITE_SENTRY_DSN=
# VITE_GA_MEASUREMENT_ID=

# --- Marketing Waitlist ---
# דף הנחיתה (/landing) שולח הרשמות ל-POST /api/marketing/waitlist,
# שמשתמש ב-RESEND_API_KEY בשרת (apps/server/.env) כדי לשלוח מייל אישור.
# אין כאן משתנה ייעודי ב-web — הכל זורם דרך ה-API.

# --- Google OAuth ---
# Client ID מ: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# סוג: Web application. הוסף Authorized JS origins: http://localhost:5852 (dev) + הדומיין שלך (prod)
VITE_GOOGLE_CLIENT_ID=

# --- PostHog (Product Analytics + Conversion Funnel) ---
# השאירי ריק כדי להשבית לחלוטין (dev mode). בפרודקשן מילוי הכרחי.
# Key מ-PostHog → Project Settings → Project API Key (phc_*)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
