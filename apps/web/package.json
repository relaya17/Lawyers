{
  "name": "@lawyers/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 5852",
    "build": "tsc --noEmit && vite build",
    "build:netlify": "tsc --noEmit && vite build",
    "build:analyze": "tsc --noEmit && ANALYZE=true vite build",
    "preview": "vite preview --host",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --reporter=verbose --passWithNoTests",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 1000"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@hookform/resolvers": "^3.3.2",
    "@mui/icons-material": "^5.18.0",
    "@mui/lab": "5.0.0-alpha.160",
    "@mui/material": "^5.18.0",
    "@mui/x-date-pickers": "^6.20.2",
    "@myorg/shared": "workspace:*",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.8.4",
    "@tanstack/react-query-devtools": "^5.8.4",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-error-boundary": "^6.1.1",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^13.5.0",
    "react-intersection-observer": "^9.5.3",
    "react-markdown": "^9.0.1",
    "react-pdf": "^10.1.0",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.20.1",
    "recharts": "^3.1.2",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/stylis": "^4.2.7",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^23.0.1",
    "lighthouse": "^13.1.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "stylis": "^4.3.0",
    "stylis-plugin-rtl": "^2.1.1",
    "terser": "^5.43.1",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.0.0"
